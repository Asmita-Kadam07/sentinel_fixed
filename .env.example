# ═══════════════════════════════════════════════════════════════════
# Project Sentinel — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Vercel), add each variable via:
#   Vercel Dashboard → Project → Settings → Environment Variables
#   OR: vercel env add VARIABLE_NAME
# ═══════════════════════════════════════════════════════════════════

# ── Anthropic ──────────────────────────────────────────────────────
# Required for the autonomous resolver (scripts/autonomous-resolver.ts)
# Obtain from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Turso (Remote SQLite) ─────────────────────────────────────────
# Required for Vercel deployment and GitHub Actions CI/CD.
# Leave BLANK for local development — the app falls back to a local
# SQLite file at monitoring/sentinel.db automatically.
#
# Steps to obtain:
#   1. Sign up at https://turso.tech (free tier: 500 databases)
#   2. Create a database: turso db create sentinel-db
#   3. Get URL:   turso db show sentinel-db --url
#   4. Get token: turso db tokens create sentinel-db
#
# URL format: libsql://<db-name>-<org>.turso.io
TURSO_DATABASE_URL=libsql://sentinel-db-<your-org>.turso.io
TURSO_AUTH_TOKEN=eyJ...

# ── Vercel (GitHub Actions deployment only) ───────────────────────
# Only needed in GitHub Actions secrets — NOT in Vercel env vars.
# Obtain from: https://vercel.com/account/tokens
VERCEL_TOKEN=
# Find in Vercel project settings → General → Project ID / Team ID
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
